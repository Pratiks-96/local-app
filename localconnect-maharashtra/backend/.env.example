PORT=4000
NODE_ENV=development

# For Docker Compose use hostname "postgres" (set automatically in docker-compose.yml)
# For manual dev with local Postgres use localhost:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/localconnect

REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -base64 32  (use TWO different values)
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key-min-32

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

S3_BUCKET=localconnect-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
USE_LOCAL_STORAGE=true
LOCAL_UPLOAD_DIR=./uploads

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@localconnect.in
