      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Users" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "Posts" },
            "properties": [{ "id": "custom.width", "value": 80 }]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 15 },
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Users" }]
      },
      "pluginVersion": "11.2.0",
      "targets": [
        {
          "expr": "localconnect_users_by_location",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Users"
        },
        {
          "expr": "localconnect_posts_by_location",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Posts"
        }
      ],
      "title": "Users & posts per society (table — click column headers to sort)",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "society" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": {
              "Value #Users": "Users",
              "Value #Posts": "Posts",
              "area": "Area",
              "city": "City",
              "society": "Society"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
