# Copy to .env:  cp .env.example .env
# Generate secrets:  openssl rand -base64 32  (run twice)

JWT_SECRET=change-me-run-openssl-rand-base64-32-here
JWT_REFRESH_SECRET=change-me-another-different-random-string

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=localconnect

# Use 8080 if port 80 is already in use on your VM (common on Azure)
HTTP_PORT=8080

FRONTEND_URL=http://20.192.29.50:8080
VM_PUBLIC_IP=20.192.29.50

DOCKERHUB_USERNAME=your-dockerhub-username

# Monitoring (optional — docker-compose.monitoring.yml)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Maps use free OpenStreetMap — no API keys needed (see docs/OPENSTREETMAP.md)
