# ===========================================
# LocalConnect Maharashtra - Environment File
# ===========================================
# Copy this file:  cp .env.example .env
# Then edit .env with your secrets (NEVER commit .env to git)

# --- JWT Secrets (REQUIRED for production) ---
# Generate with: openssl rand -base64 32
# Use TWO different random strings (run the command twice)
JWT_SECRET=change-me-run-openssl-rand-base64-32-here
JWT_REFRESH_SECRET=change-me-another-different-random-string

# --- Database (used by Docker postgres container) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=localconnect

# --- App URL (your VM public IP or domain) ---
FRONTEND_URL=http://localhost

# --- Port nginx listens on ---
HTTP_PORT=80

# --- Docker Hub (only for CI/CD production deploy) ---
DOCKERHUB_USERNAME=your-dockerhub-username
