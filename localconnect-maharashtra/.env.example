# Copy to .env:  cp .env.example .env
# Generate secrets:  openssl rand -base64 32  (run twice)

JWT_SECRET=change-me-run-openssl-rand-base64-32-here
JWT_REFRESH_SECRET=change-me-another-different-random-string

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=localconnect

# Use 8080 if port 80 is already in use on your VM (common on Azure)
HTTP_PORT=8080

FRONTEND_URL=http://localhost:8080

DOCKERHUB_USERNAME=your-dockerhub-username
